dk-lib.aws_lambda.CfnPermission","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Lambda::Permission","aws:cdk:cloudformation:props":{"action":"lambda:InvokeFunction","functionName":{"Fn::GetAtt":["SupervisorLambdaC3BF47E0","Arn"]},"principal":"bedrock.amazonaws.com","sourceArn":"arn:aws:bedrock:us-east-1:713520983597:agent/*"}}}}},"KPIAgent":{"id":"KPIAgent","path":"BankingBIAgents/KPIAgent","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgent","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::Agent","aws:cdk:cloudformation:props":{"actionGroups":[{"actionGroupName":"kpi-data-actions","actionGroupExecutor":{"lambda":{"Fn::GetAtt":["KPILambda3FE7B951","Arn"]}},"description":"Actions to retrieve KPI data from the banking database","functionSchema":{"functions":[{"name":"get_kpi_data","description":"Retrieve current KPI values and trends","parameters":{"kpi_names":{"type":"string","description":"Comma-separated KPI names: nim,npl_ratio,casa_ratio,roe_roa,cost_income,lcr_nsfr","required":true},"period":{"type":"string","description":"Period: daily, mtd, qtd, ytd","required":false}}},{"name":"get_kpi_breakdown","description":"Get KPI breakdown by business unit, product, or geography","parameters":{"kpi_name":{"type":"string","description":"KPI name to break down","required":true},"dimension":{"type":"string","description":"Breakdown dimension: business_unit, product, region","required":true}}}]}}],"agentName":"banking-bi-kpi-investigation","agentResourceRoleArn":{"Fn::GetAtt":["AgentRoleF4A42D6B","Arn"]},"autoPrepare":true,"tags":{"ManagedBy":"CDK","Phase":"3-Agents","Project":"BankingBICopilot"},"description":"Queries RDS for current KPI values and detects anomalies","foundationModel":"anthropic.claude-sonnet-4-20250514-v1:0","instruction":"You are a banking KPI investigation specialist.\nYour role is to query the banking database for current KPI values,\nidentify anomalies, and provide precise quantitative analysis.\n\nWhen investigating KPIs:\n1. Always retrieve current value AND historical comparison (WoW, MoM, YoY)\n2. Identify which business units and products are driving changes\n3. Flag any metrics breaching alert thresholds\n4. Provide basis point changes, not just percentages\n5. Never interpret — only report what the data shows\n\nUse the get_kpi_data action to retrieve KPI information.\nUse the get_kpi_breakdown action for segment/product details."}}},"DriverAgent":{"id":"DriverAgent","path":"BankingBIAgents/DriverAgent","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgent","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::Agent","aws:cdk:cloudformation:props":{"actionGroups":[{"actionGroupName":"driver-analysis-actions","actionGroupExecutor":{"lambda":{"Fn::GetAtt":["DriverLambda11B3F668","Arn"]}},"description":"Actions to analyse KPI movement drivers","functionSchema":{"functions":[{"name":"analyse_drivers","description":"Analyse drivers of KPI movements using segment correlation","parameters":{"kpi_name":{"type":"string","description":"KPI to analyse drivers for","required":true},"change_direction":{"type":"string","description":"Direction of change: up or down","required":true}}}]}}],"agentName":"banking-bi-driver-analysis","agentResourceRoleArn":{"Fn::GetAtt":["AgentRoleF4A42D6B","Arn"]},"autoPrepare":true,"tags":{"ManagedBy":"CDK","Phase":"3-Agents","Project":"BankingBICopilot"},"description":"Identifies likely drivers of KPI movements","foundationModel":"anthropic.claude-sonnet-4-20250514-v1:0","instruction":"You are a banking analytics expert specialising\nin root cause analysis of KPI movements.\n\nYour role is to identify the 3-5 most likely drivers of observed\nKPI changes, ranked by confidence. For each driver provide:\n- Clear description of the driver\n- Supporting data evidence\n- Confidence level (high/medium/low)\n- Which KPIs are affected\n\nFocus on:\n- Mix shifts (product, customer segment, geography)\n- Rate movements (pricing, funding costs)\n- Volume changes (new business, runoff, attrition)\n- Credit quality changes (NPL migration, provision movements)\n- External factors (macro, regulatory, seasonal)\n\nUse the analyse_drivers action to run correlation analysis."}}},"ValidationAgent":{"id":"ValidationAgent","path":"BankingBIAgents/ValidationAgent","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgent","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::Agent","aws:cdk:cloudformation:props":{"actionGroups":[{"actionGroupName":"validation-actions","actionGroupExecutor":{"lambda":{"Fn::GetAtt":["ValidationLambda6B331F4E","Arn"]}},"description":"Actions to validate metric calculations","functionSchema":{"functions":[{"name":"validate_metric","description":"Validate a KPI calculation against its governed definition","parameters":{"kpi_name":{"type":"string","description":"KPI to validate","required":true}}}]}}],"agentName":"banking-bi-metric-validation","agentResourceRoleArn":{"Fn::GetAtt":["AgentRoleF4A42D6B","Arn"]},"autoPrepare":true,"tags":{"ManagedBy":"CDK","Phase":"3-Agents","Project":"BankingBICopilot"},"description":"Validates KPI calculations against governed definitions","foundationModel":"anthropic.claude-sonnet-4-20250514-v1:0","instruction":"You are a banking governance and compliance specialist.\n\nYour role is to validate that KPI calculations conform to the bank's\nofficial governed metric definitions. For each KPI:\n1. Retrieve the official definition from the metric definitions library\n2. Compare the actual calculation method against the definition\n3. Verify data sources match the governed sources\n4. Confirm thresholds align with policy\n5. Flag any deviations with severity\n\nNever approve a KPI that uses a non-standard formula.\nAlways cite the specific section of the definition document.\n\nUse the validate_metric action to perform validation."}}},"SupervisorAgent":{"id":"SupervisorAgent","path":"BankingBIAgents/SupervisorAgent","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgent","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::Agent","aws:cdk:cloudformation:props":{"actionGroups":[{"actionGroupName":"pdf-report-actions","actionGroupExecutor":{"lambda":{"Fn::GetAtt":["PDFLambda24F2B082","Arn"]}},"description":"Actions to generate and deliver PDF executive reports","functionSchema":{"functions":[{"name":"generate_pdf_report","description":"Generate an executive PDF report from investigation findings","parameters":{"session_id":{"type":"string","description":"Investigation session ID","required":true},"headline":{"type":"string","description":"One-sentence headline finding","required":true},"findings_json":{"type":"string","description":"JSON string of all investigation findings","required":true},"risk_level":{"type":"string","description":"Overall risk level: low, medium, high, critical","required":true}}},{"name":"deliver_report","description":"Deliver completed PDF report via SNS to executives","parameters":{"session_id":{"type":"string","description":"Session ID of completed report","required":true},"recipient_group":{"type":"string","description":"Recipient group: board, exco, cro, cfo, all","required":false}}}]}}],"agentName":"banking-bi-supervisor","agentResourceRoleArn":{"Fn::GetAtt":["AgentRoleF4A42D6B","Arn"]},"autoPrepare":true,"tags":{"ManagedBy":"CDK","Phase":"3-Agents","Project":"BankingBICopilot"},"description":"Orchestrates KPI investigation and generates executive PDF reports","foundationModel":"anthropic.claude-sonnet-4-20250514-v1:0","instruction":"You are the Banking BI Copilot supervisor agent.\nYou orchestrate a team of specialist sub-agents to investigate\nKPI movements and produce executive-grade PDF reports.\n\nINVESTIGATION WORKFLOW:\n1. Receive investigation request (anomaly event or user question)\n2. Delegate to KPI Investigation agent to retrieve current data\n3. Delegate to Driver Analysis agent to identify root causes\n4. Delegate to Metric Validation agent to confirm calculations\n5. Synthesise all findings into a coherent narrative\n6. Generate PDF executive report via the pdf_report action\n7. Deliver report via SNS notification\n\nREPORT STANDARDS:\n- Every KPI cited must be validated by the Metric Validation agent\n- Every driver claim must have supporting data evidence\n- Risk flags must reference specific regulatory thresholds\n- Recommended actions must be specific and actionable\n- Language must be appropriate for CEO/Board audience\n\nAlways complete all four investigation steps before generating the PDF."}}},"KPIAlias":{"id":"KPIAlias","path":"BankingBIAgents/KPIAlias","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgentAlias","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::AgentAlias","aws:cdk:cloudformation:props":{"agentAliasName":"live","agentId":{"Fn::GetAtt":["KPIAgent","AgentId"]},"tags":{"ManagedBy":"CDK","Phase":"3-Agents","Project":"BankingBICopilot"},"description":"KPI Investigation agent live alias"}}},"DriverAlias":{"id":"DriverAlias","path":"BankingBIAgents/DriverAlias","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgentAlias","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::AgentAlias","aws:cdk:cloudformation:props":{"agentAliasName":"live","agentId":{"Fn::GetAtt":["DriverAgent","AgentId"]},"tags":{"ManagedBy":"CDK","Phase":"3-Agents","Project":"BankingBICopilot"},"description":"Driver Analysis agent live alias"}}},"ValidationAlias":{"id":"ValidationAlias","path":"BankingBIAgents/ValidationAlias","constructInfo":{"fqn":"aws-cdk-lib.aws_bedrock.CfnAgentAlias","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Bedrock::AgentAlias","aws:cdk:cloudformation:props":{"agentAliasName":"live","agentId":{"Fn::GetAtt":["ValidationAgent","AgentId"]},"tags":{"ManagedBy":"CDK","Phase":"3-Agents","Project":"BankingBICopilot"},"description":"Metric Validation agent live ali